# =============================================================================
# Sentinel Device Manager - Go Backend Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
#   cp .env.example .env
#
# All variables have sensible defaults for local development with DynamoDB Local.
# =============================================================================

# --- AWS / DynamoDB Configuration ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
DYNAMO_DEVICES_TABLE=sentinel-devices

# DynamoDB endpoint override. For local development with DynamoDB Local:
DYNAMODB_ENDPOINT=http://localhost:8000
# For production, leave empty to use AWS-managed DynamoDB:
# DYNAMODB_ENDPOINT=

# --- Server Ports ---
REST_PORT=8080
GRPC_PORT=9090

# --- Authentication ---
# Set to "true" to enforce JWT authentication on device management endpoints.
# Set to "false" to disable auth (development only).
AUTH_ENABLED=true

# HMAC-SHA256 secret key for JWT signing. CHANGE THIS IN PRODUCTION.
# Generate a strong key: openssl rand -base64 64
JWT_SECRET_KEY=change-me-in-production

# --- Application ---
APP_VERSION=1.0.0

# --- CORS ---
# Comma-separated list of allowed origins, or "*" for all.
CORS_ALLOWED_ORIGINS=*

# --- Logging ---
# Log level: debug, info, warn, error
LOG_LEVEL=info

# --- Observability ---
# OpenTelemetry Collector gRPC endpoint. Leave empty to disable tracing.
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
