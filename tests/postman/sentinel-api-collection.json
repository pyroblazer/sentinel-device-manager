						"pm.test('Status is 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"pm.test('Has 10+ standards', () => pm.expect(json.total).to.be.at.least(10));"
					]}}],
					"request": { "method": "GET", "url": "{{baseUrl}}/api/v1/compliance/standards" }
				},
				{
					"name": "Retention Policies",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"pm.test('Has policies', () => pm.expect(json.policies.length).to.be.above(0));",
						"json.policies.forEach(p => {",
						"    pm.test(`Policy ${p.category} has retention_days`, () => pm.expect(p.retention_days).to.be.above(0));",
						"});"
					]}}],
					"request": { "method": "GET", "url": "{{baseUrl}}/api/v1/compliance/retention" }
				},
				{
					"name": "Create Incident",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 201', () => pm.response.to.have.status(201));",
						"const json = pm.response.json();",
						"pm.test('Has incident_id', () => pm.expect(json.incident_id).to.be.a('string'));",
						"pm.test('Status is OPEN', () => pm.expect(json.status).to.eql('OPEN'));",
						"pm.test('Severity is HIGH', () => pm.expect(json.severity).to.eql('HIGH'));",
						"pm.collectionVariables.set('incidentId', json.incident_id);"
					]}}],
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/v1/compliance/incidents",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n    \"title\": \"Unauthorized access attempt\",\n    \"description\": \"Suspicious login detected from unknown IP\",\n    \"severity\": \"HIGH\",\n    \"category\": \"SECURITY\",\n    \"reported_by\": \"postman-test\"\n}" }
					}
				},
				{
					"name": "List Incidents",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"pm.test('Has incidents', () => pm.expect(json.total).to.be.above(0));"
					]}}],
					"request": { "method": "GET", "url": "{{baseUrl}}/api/v1/compliance/incidents?status=OPEN" }
				},
				{
					"name": "Update Incident",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 200', () => pm.response.to.have.status(200));"
					]}}],
					"request": {
						"method": "PUT",
						"url": "{{baseUrl}}/api/v1/compliance/incidents/{{incidentId}}",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n    \"status\": \"INVESTIGATING\",\n    \"updated_by\": \"admin\",\n    \"notes\": \"Under investigation\"\n}" }
					}
				}
			]
		},
