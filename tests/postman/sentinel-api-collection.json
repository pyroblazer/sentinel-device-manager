{
	"info": {
		"name": "Sentinel Device Manager API",
		"description": "Complete API contract tests for Sentinel Device Manager. Covers device CRUD, compliance, OWASP, superapp features, Python analytics, and security headers.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "analyticsUrl", "value": "http://localhost:8081" },
		{ "key": "deviceId", "value": "" },
		{ "key": "groupId", "value": "" },
		{ "key": "templateId", "value": "" },
		{ "key": "webhookId", "value": "" },
		{ "key": "apiKeyId", "value": "" },
		{ "key": "incidentId", "value": "" },
		{ "key": "geofenceId", "value": "" }
	],
	"item": [
		{
			"name": "Health & System",
			"item": [
				{
					"name": "Health Check",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 200', () => pm.response.to.have.status(200));",
						"pm.test('Has status field', () => {",
						"    const json = pm.response.json();",
						"    pm.expect(json.status).to.eql('ok');",
						"});",
						"pm.test('Has version field', () => {",
						"    const json = pm.response.json();",
						"    pm.expect(json.version).to.be.a('string');",
						"});"
					]}}],
					"request": { "method": "GET", "url": "{{baseUrl}}/health" }
				},
				{
					"name": "Swagger JSON",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 200', () => pm.response.to.have.status(200));",
						"pm.test('Has openapi field', () => {",
						"    const json = pm.response.json();",
						"    pm.expect(json.openapi).to.include('3.0');",
						"});",
						"pm.test('Has paths', () => {",
						"    const json = pm.response.json();",
						"    pm.expect(json.paths).to.be.an('object');",
						"});"
					]}}],
					"request": { "method": "GET", "url": "{{baseUrl}}/swagger.json" }
				}
			]
		},
		{
			"name": "Security Headers",
			"item": [
				{
					"name": "Verify Security Headers",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('X-Content-Type-Options is nosniff', () => {",
						"    pm.expect(pm.response.headers.get('X-Content-Type-Options')).to.eql('nosniff');",
						"});",
						"pm.test('X-Frame-Options is DENY', () => {",
						"    pm.expect(pm.response.headers.get('X-Frame-Options')).to.eql('DENY');",
						"});",
						"pm.test('Has HSTS header', () => {",
						"    pm.expect(pm.response.headers.get('Strict-Transport-Security')).to.include('max-age=');",
						"});",
						"pm.test('Has CSP header', () => {",
						"    pm.expect(pm.response.headers.get('Content-Security-Policy')).to.include(\"default-src 'self'\");",
						"});",
						"pm.test('Has X-XSS-Protection', () => {",
						"    pm.expect(pm.response.headers.get('X-XSS-Protection')).to.eql('1; mode=block');",
						"});",
						"pm.test('Has Permissions-Policy', () => {",
						"    pm.expect(pm.response.headers.get('Permissions-Policy')).to.include('camera=()');",
						"});",
						"pm.test('Cache-Control is no-store', () => {",
						"    pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store');",
						"});"
					]}}],
					"request": { "method": "GET", "url": "{{baseUrl}}/health" }
				}
			]
		},
		{
			"name": "OWASP",
			"item": [
				{
					"name": "OWASP Controls",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 200', () => pm.response.to.have.status(200));",
						"pm.test('Has OWASP standard name', () => {",
						"    const json = pm.response.json();",
						"    pm.expect(json.standard).to.eql('OWASP Top 10 (2021)');",
						"});",
						"pm.test('Has 10 controls', () => {",
						"    const json = pm.response.json();",
						"    pm.expect(json.controls).to.have.lengthOf(10);",
						"});",
						"pm.test('All controls have required fields', () => {",
						"    const json = pm.response.json();",
						"    json.controls.forEach(c => {",
						"        pm.expect(c).to.have.property('id');",
						"        pm.expect(c).to.have.property('name');",
						"        pm.expect(c).to.have.property('status');",
						"    });",
						"});"
					]}}],
					"request": { "method": "GET", "url": "{{baseUrl}}/api/v1/security/owasp" }
				}
			]
		},
		{
			"name": "Devices CRUD",
			"item": [
				{
					"name": "Create Device",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 201', () => pm.response.to.have.status(201));",
						"const json = pm.response.json();",
						"pm.test('Has device_id', () => pm.expect(json.device_id).to.be.a('string'));",
						"pm.test('Serial matches', () => pm.expect(json.serial_number).to.eql('PM-TEST-001'));",
						"pm.test('Status is ONLINE', () => pm.expect(json.status).to.eql('ONLINE'));",
						"pm.test('Firmware is 0.0.0', () => pm.expect(json.firmware_version).to.eql('0.0.0'));",
						"pm.collectionVariables.set('deviceId', json.device_id);"
					]}}],
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/v1/devices",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n    \"serial_number\": \"PM-TEST-001\",\n    \"device_type\": \"CAMERA\",\n    \"model\": \"D30\",\n    \"site_id\": \"site-pm\",\n    \"organization_id\": \"org-pm\",\n    \"ip_address\": \"10.0.0.1\",\n    \"mac_address\": \"AA:BB:CC:DD:EE:FF\"\n}" }
					}
				},
				{
					"name": "Get Device",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"pm.test('Device ID matches', () => pm.expect(json.device_id).to.eql(pm.collectionVariables.get('deviceId')));",
						"pm.test('Has all fields', () => {",
						"    ['device_id','serial_number','device_type','model','firmware_version','status','site_id','organization_id'].forEach(f => {",
						"        pm.expect(json).to.have.property(f);",
						"    });",
						"});"
					]}}],
					"request": { "method": "GET", "url": "{{baseUrl}}/api/v1/devices/{{deviceId}}" }
				},
				{
					"name": "List Devices",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"pm.test('Has devices array', () => pm.expect(json.devices).to.be.an('array'));",
						"pm.test('Has total field', () => pm.expect(json.total).to.be.above(0));",
						"pm.test('Has pagination', () => {",
						"    pm.expect(json).to.have.property('page');",
						"    pm.expect(json).to.have.property('limit');",
						"});"
					]}}],
					"request": { "method": "GET", "url": "{{baseUrl}}/api/v1/devices" }
				},
				{
					"name": "Update Device",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"pm.test('Model updated', () => pm.expect(json.model).to.eql('D50'));"
					]}}],
					"request": {
						"method": "PUT",
						"url": "{{baseUrl}}/api/v1/devices/{{deviceId}}",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\"model\": \"D50\"}" }
					}
				},
				{
					"name": "Create Device - Missing Fields",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 400', () => pm.response.to.have.status(400));"
					]}}],
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/v1/devices",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\"device_type\": \"CAMERA\"}" }
					}
				},
				{
					"name": "Get Nonexistent Device",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 404', () => pm.response.to.have.status(404));"
					]}}],
					"request": { "method": "GET", "url": "{{baseUrl}}/api/v1/devices/nonexistent-id" }
				},
				{
					"name": "Delete Device",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 204', () => pm.response.to.have.status(204));"
					]}}],
					"request": { "method": "DELETE", "url": "{{baseUrl}}/api/v1/devices/{{deviceId}}" }
				}
			]
		},
		{
			"name": "Compliance",
