		{
			"name": "Superapp - Geofences",
			"item": [
				{
					"name": "Create Geofence",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status is 201', () => pm.response.to.have.status(201));",
						"const json = pm.response.json();",
						"pm.test('Has coordinates', () => {",
						"    pm.expect(json.center_lat).to.eql(37.7749);",
						"    pm.expect(json.center_lng).to.eql(-122.4194);",
						"});",
						"pm.collectionVariables.set('geofenceId', json.zone_id);"
					]}}],
					"request": {
						"method": "POST",
